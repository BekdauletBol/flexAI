# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Key (or GitHub PAT for GitHub Models)
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model (gpt-4o recommended)
OPENAI_MODEL=gpt-4o

# Optional: Limit access to specific Telegram user ID
ALLOWED_USER_ID=

# Groq API Key for Whisper transcription (free at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Google Maps API Key (for Places search, reverse geocoding, directions)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# OpenWeatherMap API Key (for weather forecast)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Telegram Mini App Public URL (e.g. Railway, Render, Ngrok HTTPS URL)
WEBAPP_URL=your_public_webapp_url_here

# Port for Express server
PORT=3000