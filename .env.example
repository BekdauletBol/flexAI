# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Key (or GitHub PAT for GitHub Models)
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model
OPENAI_MODEL=gpt-4o

# Optional: Limit access to specific Telegram user ID
ALLOWED_USER_ID=

# Groq API Key for Whisper transcription (free at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here